# =============================================================================
# Aiscern — Environment Variables Template
# Copy to .env.local (never commit .env.local to git)
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://aiscern.com

# ── Clerk Auth ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxx
CLERK_SECRET_KEY=sk_live_xxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── AUTH DB: Supabase (users, credits, billing) ───────────────────────────────
# Use POOLER URL for all runtime queries (PgBouncer on port 6543)
NEXT_PUBLIC_SUPABASE_URL=https://lpgzmruxaeikxxayjmze.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_DB_PASSWORD=your-db-password
# Pooler URL format: postgresql://postgres.PROJECT_ID:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
SUPABASE_POOLER_URL=postgresql://postgres.lpgzmruxaeikxxayjmze:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
# Direct URL — migrations only (no pgbouncer=true suffix)
SUPABASE_DIRECT_URL=postgresql://postgres:PASSWORD@db.lpgzmruxaeikxxayjmze.supabase.co:5432/postgres

# ── HEAVY DB: Neon (scans, forensic layers, file metadata) ───────────────────
# Sign up: neon.tech → create project → copy connection string
# Use -pooler.neon.tech hostname to enable PgBouncer
NEON_POOLER_URL=postgresql://USER:PASSWORD@PROJECT-pooler.us-east-2.aws.neon.tech/neondb?pgbouncer=true&sslmode=require
NEON_DIRECT_URL=postgresql://USER:PASSWORD@PROJECT.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── ANALYTICS DB: CockroachDB Serverless (logs, metrics, saga outbox) ─────────
# Sign up: cockroachlabs.cloud → create serverless cluster → copy connection string
COCKROACH_URL=postgresql://USER:PASSWORD@free-tier14.aws-us-east-1.cockroachlabs.cloud:26257/defaultdb?sslmode=verify-full

# ── AI / ML ───────────────────────────────────────────────────────────────────
HUGGINGFACE_API_KEY=hf_xxxx
GEMINI_API_KEY=AIzaSy_xxxx
NVIDIA_NIM_API_KEY=nvapi-xxxx

# ── Cloudflare ────────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=34400e6e147e83e95c942135f54aeba7
CLOUDFLARE_R2_ENDPOINT=https://34400e6e147e83e95c942135f54aeba7.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY_ID=xxxx
CLOUDFLARE_R2_SECRET_ACCESS_KEY=xxxx
CLOUDFLARE_R2_BUCKET_NAME=aiscern-uploads
CLOUDFLARE_D1_DATABASE_ID=50f5e26a-c794-4cfa-b2b7-2bbd1d7c045c
CLOUDFLARE_API_TOKEN=xxxx

# ── Upstash Redis (rate limiting + scan cache) ────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx

# ── Inngest (background jobs) ─────────────────────────────────────────────────
INNGEST_SIGNING_KEY=signkey-prod-xxxx
INNGEST_EVENT_KEY=xxxx

# ── XPay by PostEx (primary Pakistan payment gateway) ────────────────────────
# Sandbox: https://stg-ta.nexigroup.com/api/phoenix-0.0/psp/api/v1
# Live:    https://xpay.nexigroup.com/api/phoenix-0.0/psp/api/v1
# Test API key (sandbox only — do NOT use in production):
#   5d952446-9004-4023-9eae-a527a152846b
XPAY_API_URL=https://xpay.nexigroup.com/api/phoenix-0.0/psp/api/v1
XPAY_API_KEY=your-live-api-key
XPAY_SECRET_KEY=your-hmac-secret
XPAY_MERCHANT_ID=your-merchant-id

# ── Stripe (fallback for international cards) ─────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ── JazzCash (secondary Pakistan gateway — optional) ─────────────────────────
JAZZCASH_MERCHANT_ID=MCxxxx
JAZZCASH_PASSWORD=xxxx
JAZZCASH_INTEGRITY_SALT=xxxx
JAZZCASH_RETURN_URL=https://aiscern.com/api/webhook/jazzcash

# ── Load balancer origin URLs ─────────────────────────────────────────────────
VERCEL_ORIGIN=https://aiscern.vercel.app
NETLIFY_ORIGIN=https://aiscern.netlify.app
CF_PAGES_ORIGIN=https://aiscern.pages.dev

# ── Deployment origin (set per-platform) ─────────────────────────────────────
# Vercel sets VERCEL_URL automatically — do not set manually on Vercel
# On Netlify, set NEXT_PUBLIC_APP_URL manually in Netlify dashboard
